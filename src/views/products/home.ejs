                    <div class="PD_title-buttons">
                        <button type="button" class="buttonArrow" aria-label="Anterior">
                            <svg class="icon">
                                <use href="/images/sprite.svg#icon-arrow"></use>
                            </svg>
                        </button>
                        <button type="button" class="buttonArrow arrowRight" aria-label="Siguiente">
                            <svg class="icon">
                                <use href="/images/sprite.svg#icon-arrow"></use>
                            </svg>
                        </button>
                    </div>
                </div>
                <nav class="PD_navigation">
                    <button type="button" class="buttonArrow" aria-label="Anterior">
                        <svg class="icon">
                            <use href="/images/sprite.svg#icon-arrow"></use>
                        </svg>
                    </button>
                    <ul class="PD_ul-navigation">
                        <li>
                            <button type="button"
                                class="PD_navigation-button PD_navigation-button-active">Perifericos</button>
                        </li>
                        <li>
                            <button type="button" class="PD_navigation-button">Monitores</button>
                        </li>
                        <li>
                            <button type="button" class="PD_navigation-button">Placas de video</button>
                        </li>
                        <li>
                            <button type="button" class="PD_navigation-button">Motherboards</button>
                        </li>
                        <li>
                            <button type="button" class="PD_navigation-button">Gabinetes</button>
                        </li>
                        <li>
                            <button type="button" class="PD_navigation-button">Memorias RAM</button>
                        </li>
                        <li>
                            <button type="button" class="PD_navigation-button">Almacenamiento</button>
                        </li>
                    </ul>
                    <button type="button" class="buttonArrow arrowRight" aria-label="Siguiente">
                        <svg class="icon">
                            <use href="/images/sprite.svg#icon-arrow"></use>
                        </svg>
                    </button>
                </nav>
                <ul class="PD_products-list">
                    <%- include("../partials/home/PD-productCard", { link: "#" ,
                        image: "/images/home/Productos/Imagen-mouse.jpg" ,
                        name: "Logitech G703 Wireless HERO 2.4GHz RGB" , discount: "$ 94.999,99" , price: "$ 89.999,99"
                        })%>
                        <%- include("../partials/home/PD-productCard", { link: "#" ,
                            image: "/images/home/Productos/Imagen-microfono.jpg" ,
                            name: "Microfono SteelSeries RGB ANC USB-C" , discount: "$ 311.524,99" ,
                            price: "$ 295.949,99" })%>
                            <%- include("../partials/home/PD-productCard", { link: "#" ,
                                image: "/images/home/Productos/Imagen-teclado.jpg" ,
                                name: "Teclado Redragon Mitra K551 Mechanical RGB" , discount: "$ 63.149,99" ,
                                price: "$ 59.999,99" , hasPadding: true })%>
                                <%- include("../partials/home/PD-productCard", { link: "#" ,
                                    image: "/images/home/Productos/Imagen-auriculares.jpg" ,
                                    name: "Auriculares Redragon Lamia H320 RGB 7.1 Black" , discount: "$ 71.159,99" ,
                                    price: "$ 67.599,99" })%>
