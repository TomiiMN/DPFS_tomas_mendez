                            <svg class="icon">
                                <use href="/images/sprite.svg#icon-arrow"></use>
                            </svg>
                        </button>
                        <button type="button" class="buttonArrow arrowRight" aria-label="Siguiente">
                            <svg class="icon">
                                <use href="/images/sprite.svg#icon-arrow"></use>
