                        , type: "Placa de video" , price: "$ 1.199.750" , hasPadding: true }) %>
                        <%- include("../partials/home/LN-newsCard", { link: "#" ,
                            image: "/images/home/Novedades/Imagen-notebook.jpg" , name: "Vivobook Go 15 R5 512GB SSD" ,
                            type: "Notebook" , price: "$ 706.900" , hasPadding: true }) %>
                            <%- include("../partials/home/LN-newsCard", { link: "#" ,
                                image: "/images/home/Novedades/Imagen-silla-gamer.jpg" , name: "Razer Iskur Tela 2D" ,
                                type: "Silla gamer" , price: "$ 484.650" , }) %>
                                <%- include("../partials/home/LN-newsCard", { link: "#" ,
                                    image: "/images/home/Novedades/Imagen-monitor.jpg" ,
                                    name: "Samsung G9 Potencia Total" , type: "Monitores" , price: "$ 1.764.900" ,
                                    hasPadding: true }) %>
