<%- include("../partials/global/head", { title: "TechBox" , css: "index-style" }) %>
    <%- include("../partials/global/header", { showNav: true }) %>
        <main>
            <section class="carrusel" aria-label="Carrusel principal">
                <button type="button" class="buttonArrow" aria-label="Anterior" id="carrusel_LeftArrow">
                    <svg class="icon">
                        <use href="/images/sprite.svg#icon-arrow"></use>
                    </svg>
                </button>
                <div class="carrusel_container-carrusel">
                    <div class="carrusel_track">
                        <img src="/images/home/imagen-carrusel1.jpg" alt="Publicidad carrusel 1"
                            class="carrusel_carrusel-img carrusel-slide carrusel-slide--active">
                        <img src="/images/home/imagen-carrusel2.jpg" alt="Publicidad carrusel 2"
                            class="carrusel_carrusel-img carrusel-slide">
                        <img src="/images/home/imagen-carrusel3.jpg" alt="Publicidad carrusel 3"
                            class="carrusel_carrusel-img carrusel-slide">
                    </div>
                    <div class="slide-tab" role="tablist">
                        <button class="slide slide-active" role="tab" aria-selected="true"
                            aria-label="Slide 1"></button>
                        <button class="slide" role="tab" aria-selected="false" aria-label="Slide 2"></button>
                        <button class="slide" role="tab" aria-selected="false" aria-label="Slide 3"></button>
                    </div>
                </div>
                <button type="button" class="buttonArrow arrowRight" aria-label="Siguiente" id="carrusel_RightArrow">
                    <svg class="icon">
                        <use href="/images/sprite.svg#icon-arrow"></use>
                    </svg>
                </button>
            </section>

            <section class="productosDestacados">
                <div class="PD_title">
                    <h2 class="title-h2">Conocé nuestros <strong class="title-strong-h2">productos destacados</strong>
                    </h2>
                    <div class="PD_title-buttons">
                        <button type="button" class="buttonArrow" aria-label="Anterior">
                            <svg class="icon">
                                <use href="/images/sprite.svg#icon-arrow"></use>
                            </svg>
                        </button>
                        <button type="button" class="buttonArrow arrowRight" aria-label="Siguiente">
                            <svg class="icon">
                                <use href="/images/sprite.svg#icon-arrow"></use>
                            </svg>
                        </button>
                    </div>
                </div>
                <nav class="PD_navigation">
                    <button type="button" class="buttonArrow" aria-label="Anterior">
                        <svg class="icon">
                            <use href="/images/sprite.svg#icon-arrow"></use>
                        </svg>
                    </button>
                    <ul class="PD_ul-navigation">
                        <li>
                            <button type="button" data-cat="periferico"
                                class="PD_navigation-button PD_navigation-button-active">Periféricos</button>
                        </li>
                        <li>
                            <button type="button" data-cat="procesador"
                                class="PD_navigation-button">Procesadores</button>
                        </li>
                        <li>
                            <button type="button" data-cat="monitor" class="PD_navigation-button">Monitores</button>
                        </li>
                        <li>
                            <button type="button" data-cat="placa-de-video" class="PD_navigation-button">Placas de
                                video</button>
                        </li>
                        <li>
                            <button type="button" data-cat="motherboard"
                                class="PD_navigation-button">Motherboards</button>
                        </li>
                        <li>
                            <button type="button" data-cat="gabinete" class="PD_navigation-button">Gabinetes</button>
                        </li>
                        <li>
                            <button type="button" data-cat="memoria-ram" class="PD_navigation-button">Memorias
                                RAM</button>
                        </li>
                        <li>
                            <button type="button" data-cat="almacenamiento"
                                class="PD_navigation-button">Almacenamiento</button>
                        </li>
                    </ul>
                    <button type="button" class="buttonArrow arrowRight" aria-label="Siguiente">
                        <svg class="icon">
                            <use href="/images/sprite.svg#icon-arrow"></use>
                        </svg>
                    </button>
                </nav>
                <ul class="PD_products-list">
                    <% featuredProducts.forEach(product=> { %>
                        <%- include("../partials/home/product-card", { product }) %>
                            <% }) %>
                </ul>
                <p id="PD_empty-message" class="home-empty-message" style="display:none">No se ha encontrado ningun
                    producto en descuento dentro de esta categoría</p>
            </section>
            <section class="lastNews">
                <h2 class="title-h2 LN_title">Conocé los <strong class="title-strong-h2">últimos lanzamientos</strong>
                </h2>
                <ul class="LN_news-list">
                    <% latestProducts.forEach(product=> { %>
                        <%- include("../partials/home/news-card", { product }) %>
                            <% }) %>
                </ul>
            </section>
            <section class="brands">
                <div class="BR_title">
                    <h2 class="title-h2">Descubrí las <strong class="title-strong-h2">mejores marcas</strong></h2>
                    <div class="BR_title-buttons">
                        <button type="button" class="buttonArrow" aria-label="Anterior">
                            <svg class="icon">
                                <use href="/images/sprite.svg#icon-arrow"></use>
                            </svg>
                        </button>
                        <button type="button" class="buttonArrow arrowRight" aria-label="Siguiente">
                            <svg class="icon">
                                <use href="/images/sprite.svg#icon-arrow"></use>
                            </svg>
                        </button>
                    </div>
                </div>
                <div class="BR_navigation">
                    <button type="button" class="buttonArrow" id="BR_arrow--left" aria-label="Anterior">
                        <svg class="icon">
                            <use href="/images/sprite.svg#icon-arrow"></use>
                        </svg>
                    </button>
                    <nav>
                        <ul class="BR_ul-navigation">
                            <li>
                                <button type="button"
                                    class="BR_navigation-button BR_navigation-button-active">ASUS</button>
                            </li>
                            <li>
                                <button type="button" class="BR_navigation-button">AMD</button>
                            </li>
                            <li>
                                <button type="button" class="BR_navigation-button">Logitech</button>
                            </li>
                            <li>
                                <button type="button" class="BR_navigation-button">Intel</button>
                            </li>
                            <li>
                                <button type="button" class="BR_navigation-button">Corsair</button>
                            </li>
                            <li>
                                <button type="button" class="BR_navigation-button">Hyte</button>
                            </li>
                            <li>
                                <button type="button" class="BR_navigation-button">NVIDIA</button>
                            </li>
                            <li>
                                <button type="button" class="BR_navigation-button">Steelseries</button>
                            </li>
                            <li>
                                <button type="button" class="BR_navigation-button">Razer</button>
                            </li>
                            <li>
                                <button type="button" class="BR_navigation-button">Redragon</button>
                            </li>
                            <li>
                                <button type="button" class="BR_navigation-button">Samsung</button>
                            </li>
                        </ul>
                    </nav>
                    <button type="button" class="buttonArrow arrowRight" id="BR_arrow--right" aria-label="Siguiente">
                        <svg class="icon">
                            <use href="/images/sprite.svg#icon-arrow"></use>
                        </svg>
                    </button>
                </div>
                <div class="BR_brand-products">
                    <ul class="BR_brand-list-items">
                        <% brandProducts.forEach(product=> { %>
                            <%- include("../partials/home/brand-item-card", { product }) %>
                                <% }) %>
                    </ul>
                    <p id="BR_empty-message" class="home-empty-message" style="display:none">No se ha encontrado ningun
                        producto de esta marca</p>
                </div>
            </section>
        </main>
        <%- include("../partials/global/footer") %>
            <script id="home-category-data" type="application/json">
            <%- JSON.stringify(parentCategories.map(pc => ({
                slug: pc.slug,
                ids: [pc.id, ...categories.filter(c => c.parent_id === pc.id).map(c => c.id)]
            }))) %>
        </script>
            <%- include("../partials/global/scripts", { js: "home" }) %>
                </body>

                </html>