<%- include("../partials/global/head", { title: "Admin - Detail" , css: "admin-detail-style" }) %>
    <main>
        <div class="breadcrumb"><a href="/">Home</a>/<a href="/admin/products">Products</a>/<span><%= product.name %></span>
        </div>

        <header class="page-header">
            <h1 class="page-title">Detalle del producto</h1>
            <div class="header-actions">
                <form action="/admin/products/<%= product.id %>?_method=DELETE" method="POST" style="display:inline;">
                    <button class="btn btn-danger"
                        onclick="return confirm('¿Seguro que querés eliminar este producto?')">
                        Eliminar
                    </button>
                </form>
                <div class="mode-toggle">
                    <button class="mode-btn active">✦ Detalle</button>
                    <a href="/admin/products/<%= product.id %>/edit" class="mode-btn">Editar</a>
                </div>
            </div>
        </header>

        <div class="layout">

            <!-- LEFT COLUMN -->
            <section class="left-column">

                <!-- Información básica -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-icon">
                            <svg class="icon-detail-admin">
                                <use href="/images/sprite.svg#icon-menu-alt"></use>
                            </svg>
                        </div>
                        <span class="card-title">Información básica</span>
                    </div>

                    <div class="field-grid">
                        <div class="field" style="grid-column: span 2">
                            <span class="field-label">Nombre</span>
                            <span class="field-value">
                                <%= product.name %>
                            </span>
                        </div>
                    </div>
                    <div class="field-grid">
                        <div class="field">
                            <span class="field-label">Marca</span>
                            <span class="field-value">
                                <%= product.brand %>
                            </span>
                        </div>
                        <div class="field">
                            <span class="field-label">Modelo</span>
                            <span class="field-value">
                                <%= product.model %>
                            </span>
                        </div>
                    </div>
                    <div class="field-grid">
                        <div class="field">
                            <span class="field-label">Categoría</span>
                            <span class="field-value">
                                <%= product.categories && product.categories[0] ? product.categories[0].name : '-' %>
                            </span>
                        </div>
                        <div class="field">
                            <span class="field-label">Subcategoría</span>
                            <span class="field-value">
                                <%= product.categories && product.categories[1] ? product.categories[1].name : '-' %>
                            </span>
                        </div>
                    </div>
                    <div class="field-grid">
                        <div class="field">
                            <span class="field-label">Tier</span>
                            <span class="field-value">
                                <%= product.tier ? product.tier.charAt(0).toUpperCase() + product.tier.slice(1) : '-' %>
                            </span>
                        </div>
                        <div class="field">
                            <span class="field-label">Fecha de lanzamiento</span>
                            <span class="field-value muted">
                                <%= product.release_date ? new Date(product.release_date).toLocaleDateString('es-AR') : '-' %>
                            </span>
                        </div>
                    </div>

                    <hr class="divider">

                    <div class="field">
                        <span class="field-label" style="margin-bottom:6px">Tags</span>
                        <div class="badge-row">
                            <% if (product.tags && product.tags.length > 0) { %>
                                <% product.tags.forEach(tag => { %>
                                    <span class="badge badge-purple">
                                        <%= tag.name.charAt(0).toUpperCase() + tag.name.slice(1) %>
                                    </span>
                                <% }) %>
                            <% } else { %>
                                <span class="field-value muted">Sin tags</span>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- Precio -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-icon">
                            <svg class="icon-detail-admin">
                                <use href="/images/sprite.svg#icon-help"></use>
                            </svg>
                        </div>
                        <span class="card-title">Precio</span>
                    </div>
                    <% let discount = 0;
                       const hasDiscount = product.old_price && product.old_price > product.price;
                       if (hasDiscount) {
                           discount = Math.round(((product.old_price - product.price) / product.old_price) * 100);
                       }
                       const formattedPrice = product.price.toLocaleString("es-AR");
                       const formattedOldPrice = product.old_price ? product.old_price.toLocaleString("es-AR") : null;
                    %>

                    <div class="field-grid">
                        <div class="field">
                            <span class="field-label">Precio actual</span>
                            <div class="price-row">
                                <span class="field-value large">$ <%= formattedPrice %></span>
                                <% if (hasDiscount) { %>
                                    <span class="discount-pill">
                                        <%= discount %>% off
                                    </span>
                                <% } %>
                            </div>
                        </div>
                        <% if (hasDiscount) { %>
                            <div class="field">
                                <span class="field-label">Precio original</span>
                                <span class="field-value strike">$ <%= formattedOldPrice %></span>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Especificaciones -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-icon">
                            <svg class="icon-detail-admin">
                                <use href="/images/sprite.svg#icon-grid"></use>
                            </svg>
                        </div>
                        <span class="card-title">Especificaciones</span>
                    </div>
                    <table class="specs-table">
                        <% if (product.specs && product.specs.length > 0) { %>
                            <% product.specs.forEach(spec => { %>
                                <tr>
                                    <td><%= specsLabels[spec.name] || spec.name %></td>
                                    <% const displayValue = spec.value === "true" ? "Sí" : spec.value === "false" ? "No" : (typeof spec.value === "string" ? spec.value.charAt(0).toUpperCase() + spec.value.slice(1) : spec.value); %>
                                    <td><%= displayValue %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="2" class="muted">Sin especificaciones</td></tr>
                        <% } %>
                    </table>
                </div>

            </section>

            <!-- RIGHT COLUMN -->
            <section>

                <!-- Imagen -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-icon">
                            <svg class="icon-detail-admin">
                                <use href="/images/sprite.svg#icon-image"></use>
                            </svg>
                        </div>
                        <span class="card-title">Imagen del producto</span>
                    </div>
                    <img class="product-image" src="<%= product.img %>" alt="<%= product.name %>">
                </div>

                <!-- Estado -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-icon">
                            <svg class="icon-detail-admin">
                                <use href="/images/sprite.svg#icon-info"></use>
                            </svg>
                        </div>
                        <span class="card-title">Estado</span>
                    </div>
                    <div style="display:flex; flex-direction:column; gap:12px">
                        <div class="field">
                            <span class="field-label">Estado</span>
                            <div style="margin-top:4px"><span class="badge badge-green">
                                    <%= product.state ? "Publicado" : "No publicado" %>
                                </span></div>
                        </div>
                        <div class="field">
                            <span class="field-label">Flags</span>
                            <div class="badge-row" style="margin-top:4px">
                                <% if (product.featured) { %>
                                    <span class="badge badge-purple2">Destacado</span>
                                <% } %>
                                <% if (product.on_sale) { %>
                                    <span class="badge badge-red">En oferta</span>
                                <% } %>
                                <% if (!product.featured && !product.on_sale) { %>
                                    <span class="field-value muted">Sin flags</span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>

            </section>
        </div>
    </main>

    </body>

    </html>
