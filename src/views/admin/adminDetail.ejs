<%- include("../partials/global/head", { title: "Admin - Detail" , css: "adminDetailStyle" }) %>
    <main>
        <div class="breadcrumb">
            <a href="#">Admin</a>
            <span>/</span>
            <a href="/admin/products">Products</a>
            <span>/</span>
            <span>
                <%= product.name %>
            </span>
        </div>

        <div class="page-header">
            <h1 class="page-title">Detalle del producto</h1>
            <div class="header-actions">
                <button class="btn btn-danger">Eliminar</button>
                <div class="mode-toggle">
                    <button class="mode-btn active">✦ Detalle</button>
                    <a href="/admin/<%= product.id %>/edit" class="mode-btn">Editar</a>
                </div>
            </div>
        </div>

        <div class="layout">

            <!-- LEFT COLUMN -->
            <div class="left-column">

                <!-- Información básica -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-icon">
                            <svg viewBox="0 0 16 16">
                                <path d="M2 3h12v2H2zm0 4h8v2H2zm0 4h6v2H2z" />
                            </svg>
                        </div>
                        <span class="card-title">Información básica</span>
                    </div>

                    <div class="field-grid">
                        <div class="field" style="grid-column: span 2">
                            <span class="field-label">Nombre</span>
                            <span class="field-value">
                                <%= product.name %>
                            </span>
                        </div>
                    </div>
                    <div class="field-grid">
                        <div class="field">
                            <span class="field-label">Marca</span>
                            <span class="field-value">
                                <%= product.brand %>
                            </span>
                        </div>
                        <div class="field">
                            <span class="field-label">Modelo</span>
                            <span class="field-value">
                                <%= product.model %>
                            </span>
                        </div>
                    </div>
                    <div class="field-grid">
                        <div class="field">
                            <span class="field-label">Categoría</span>
                            <span class="field-value">
                                <%= product.category[0].name %>
                            </span>
                        </div>
                        <div class="field">
                            <span class="field-label">Subcategoría</span>
                            <span class="field-value">
                                <%= product.category[1].name %>
                            </span>
                        </div>
                    </div>
                    <div class="field-grid">
                        <div class="field">
                            <span class="field-label">Tier</span>
                            <span class="field-value">
                                <%= product.tier.charAt(0).toUpperCase() + product.tier.slice(1) %>
                            </span>
                        </div>
                        <div class="field">
                            <span class="field-label">Fecha de lanzamiento</span>
                            <span class="field-value muted">
                                <%= product.releaseDate %>
                            </span>
                        </div>
                    </div>

                    <hr class="divider">

                    <div class="field">
                        <span class="field-label" style="margin-bottom:6px">Tags</span>
                        <div class="badge-row">
                            <% product.tags.forEach(tag=> { %>
                                <span class="badge badge-purple">
                                    <%= tag.charAt(0).toUpperCase() + tag.slice(1) %>
                                </span>
                                <% }) %>
                        </div>
                    </div>
                </div>

                <!-- Precio -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-icon">
                            <svg viewBox="0 0 16 16">
                                <path
                                    d="M8 1a7 7 0 100 14A7 7 0 008 1zm1 10.5H7v-1.5h2v1.5zm0-3H7c0-2 2-1.5 2-3 0-.8-.9-1-1-1s-1 .2-1 1H7c0-1.7 1.3-2 2-2s2 .3 2 2c0 2-2 1.5-2 3z" />
                            </svg>
                        </div>
                        <span class="card-title">Precio</span>
                    </div>
                    <% let discount=0; const hasDiscount=product.oldPrice && product.oldPrice> product.price;

                        if (hasDiscount) {
                        discount = Math.round(((product.oldPrice - product.price) / product.oldPrice) * 100);
                        }

                        const formattedPrice = product.price.toLocaleString("es-AR");
                        const formattedOldPrice = product.oldPrice?.toLocaleString("es-AR");
                        %>

                        <div class="field-grid">
                            <div class="field">
                                <span class="field-label">Precio actual</span>
                                <div class="price-row">
                                    <span class="field-value large">$ <%= formattedPrice %></span>

                                    <% if (hasDiscount) { %>
                                        <span class="discount-pill">
                                            <%= discount %>% off
                                        </span>
                                        <% } %>

                                </div>
                            </div>

                            <% if (hasDiscount) { %>
                                <div class="field">
                                    <span class="field-label">Precio original</span>
                                    <span class="field-value strike">$ <%= formattedOldPrice %></span>
                                </div>
                                <% } %>
                        </div>
                </div>

                <!-- Especificaciones -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-icon">
                            <svg viewBox="0 0 16 16">
                                <path
                                    d="M3 2h10a1 1 0 011 1v10a1 1 0 01-1 1H3a1 1 0 01-1-1V3a1 1 0 011-1zm1 2v8h8V4H4zm1 1h2v2H5zm4 0h2v2H9zm-4 4h2v2H5zm4 0h2v2H9z" />
                            </svg>
                        </div>
                        <span class="card-title">Especificaciones</span>
                    </div>
                    <table class="specs-table">
                        <% for (let key in product.specs) { %>
                            <tr>
                                <!-- Label bonito -->
                                <td>
                                    <%= specsLabels[key] || key %>
                                </td>

                                <!-- Valor -->
                                <td>
                                    <%= typeof product.specs[key]==="string" ?
                                        product.specs[key].charAt(0).toUpperCase() + product.specs[key].slice(1) :
                                        product.specs[key] %>
                                </td>
                            </tr>
                            <% } %>
                    </table>
                </div>

            </div>

            <!-- RIGHT COLUMN -->
            <div>

                <!-- Imagen -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-icon">
                            <svg viewBox="0 0 16 16">
                                <path
                                    d="M1 2h14v12H1V2zm1 1v8.5l3.5-4 3 3.5 2-2.5L14 12V3H2zm10 2a1 1 0 11-2 0 1 1 0 012 0z" />
                            </svg>
                        </div>
                        <span class="card-title">Imagen del producto</span>
                    </div>
                    <img class="product-image" src="<%= product.img %>" alt="<%= product.name %>">
                </div>

                <!-- Estado -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-icon">
                            <svg viewBox="0 0 16 16">
                                <path
                                    d="M8 1a7 7 0 100 14A7 7 0 008 1zm-.75 4h1.5v4.5h-1.5V5zm0 5.5h1.5v1.5h-1.5V10.5z" />
                            </svg>
                        </div>
                        <span class="card-title">Estado</span>
                    </div>
                    <div style="display:flex; flex-direction:column; gap:12px">
                        <div class="field">
                            <span class="field-label">Estado</span>
                            <div style="margin-top:4px"><span class="badge badge-green">
                                    <%= product.state %>
                                </span></div>
                        </div>
                        <div class="field">
                            <span class="field-label">Flags</span>
                            <div class="badge-row" style="margin-top:4px">
                                <% if (product.flags?.featured) { %>
                                    <span class="badge badge-purple2">Destacado</span>
                                    <% } %>

                                        <% if (product.flags?.onSale) { %>
                                            <span class="badge badge-red">En oferta</span>
                                            <% } %>

                                                <% if (!product.flags || (!product.flags.featured &&
                                                    !product.flags.onSale)) { %>
                                                    <span class="field-value muted">Sin flags</span>
                                                    <% } %>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </main>

    </body>

    </html>