<% if (typeof js !=="undefined" && js) { %>
    <% if (Array.isArray(js)) { %>
        <% js.forEach(file=> { %>
            <script src="/js/<%= file %>.js"></script>
            <% }) %>
                <% } else { %>
                    <script src="/js/<%= js %>.js"></script>
                    <% } %>
                        <% } %>