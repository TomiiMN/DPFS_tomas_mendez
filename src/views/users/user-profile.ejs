<%- include("../partials/global/head", { title: "Perfil" , css: "user-profile-style" }) %>
    <%- include("../partials/global/header", { showNav: true }) %>
        <%- include("../partials/global/alerts") %>

            <main class="profile-main">
                <div class="profile-container">
                    <aside class="profile-sidebar">
                        <div class="profile-avatar-wrapper">
                            <% if (user.avatar && user.avatar.trim() !=='' ) { %>
                                <img src="<%= user.avatar %>" alt="Avatar de <%= user.first_name %>"
                                    class="profile-avatar">
                                <% } else { %>
                                    <img src="/images/avatars/default.png" alt="Avatar por defecto"
                                        class="profile-avatar">
                                    <% } %>
                                        <a class="profile-avatar-edit-btn" href="#avatar">
                                            <svg class="icon-edit">
                                                <use href="/images/sprite.svg#icon-edit"></use>
                                            </svg>
                                        </a>
                        </div>

                        <div class="profile-sidebar-info">
                            <h2 class="profile-fullname">
                                <%= user.first_name %>
                                    <%= user.last_name %>
                            </h2>
                            <span class="profile-badge <%= user.type === 'Admin' ? 'badge-admin' : 'badge-customer' %>">
                                <%= user.type==='Admin' ? 'Administrador' : 'Cliente' %>
                            </span>
                        </div>
                        <nav class="profile-sidebar-nav">
                            <a href="#info" class="profile-nav-item active">
                                <svg class="icon-nav-profile">
                                    <use href="/images/sprite.svg#icon-user"></use>
                                </svg>
                                Información personal
                            </a>
                            <a href="#security" class="profile-nav-item">
                                <svg class="icon-nav-profile">
                                    <use href="/images/sprite.svg#icon-lock"></use>
                                </svg>
                                Seguridad
                            </a>
                            <a href="#avatar" class="profile-nav-item">
                                <svg class="icon-nav-profile">
                                    <use href="/images/sprite.svg#icon-user-avatar"></use>
                                </svg>
                                Avatar
                            </a>
                            <form action="/users/logout" method="POST">
                                <button type="submit" class="profile-nav-item profile-nav-logout">
                                    <svg class="icon-nav-profile">
                                        <use href="/images/sprite.svg#icon-logout"></use>
                                    </svg>
                                    Cerrar sesión
                                </button>
                            </form>
                        </nav>
                    </aside>
                    <div class="profile-content">
                        <section class="profile-section" id="info">
                            <div class="profile-section-header">
                                <h3 class="profile-section-title">Información personal</h3>
                                <button class="profile-edit-btn" id="editInfoBtn">
                                    <svg class="icon-edit">
                                        <use href="/images/sprite.svg#icon-edit"></use>
                                    </svg>
                                    Editar
                                </button>
                            </div>
                            <form class="profile-form" id="infoForm" method="POST"
                                action="/users/update-info/<%= user.id %>">
                                <div class="profile-form-group">
                                    <label class="profile-label">Nombre</label>
                                    <input type="text" class="profile-input"
                                        value="<%= oldData?.firstName || user.first_name %>" name="firstName" disabled>
                                </div>
                                <div class="profile-form-group">
                                    <label class="profile-label">Apellido</label>
                                    <input type="text" class="profile-input"
                                        value="<%= oldData?.lastName || user.last_name %>" name="lastName" disabled>
                                </div>
                                <div class="profile-form-group">
                                    <label class="profile-label">Correo electrónico</label>
                                    <input type="email" class="profile-input"
                                        value="<%= oldData?.email || user.email %>" name="email" disabled>
                                </div>
                                <div class="profile-form-group">
                                    <label class="profile-label">Nombre de usuario</label>
                                    <input type="text" class="profile-input"
                                        value="<%= oldData?.username || user.username %>" name="username" disabled>
                                </div>
                                <div class="profile-form-actions" id="infoActions" style="display: none;">
                                    <button type="button" class="profile-btn-cancel"
                                        id="cancelInfoBtn">Cancelar</button>
                                    <button type="submit" class="profile-btn-save">Guardar cambios</button>
                                </div>
                            </form>
                        </section>
                        <section class="profile-section" id="security">
                            <div class="profile-section-header">
                                <h3 class="profile-section-title">Seguridad</h3>
                            </div>
                            <form class="profile-form" id="securityForm" method="POST"
                                action="/users/update-password/<%= user.id %>">
                                <div class="profile-form-group profile-form-group--full">
                                    <label class="profile-label">Contraseña actual</label>
                                    <div class="profile-input-wrapper">
                                        <input type="password" class="profile-input"
                                            value="<%= oldData?.currentPassword || '' %>" name="currentPassword"
                                            placeholder="Ingresá tu contraseña actual">
                                        <button type="button" class="profile-toggle-password"
                                            title="Mostrar/ocultar contraseña">
                                            <svg class="icon-password-toggle">
                                                <use href="/images/sprite.svg#icon-eye-alt"></use>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                                <div class="profile-form-group">
                                    <label class="profile-label">Nueva contraseña</label>
                                    <div class="profile-input-wrapper">
                                        <input type="password" class="profile-input" name="newPassword"
                                            placeholder="Nueva contraseña">
                                        <button type="button" class="profile-toggle-password"
                                            title="Mostrar/ocultar contraseña">
                                            <svg class="icon-password-toggle">
                                                <use href="/images/sprite.svg#icon-eye-alt"></use>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                                <div class="profile-form-group">
                                    <label class="profile-label">Confirmar contraseña</label>
                                    <div class="profile-input-wrapper">
                                        <input type="password" class="profile-input" name="confirmPassword"
                                            placeholder="Repetí la nueva contraseña">
                                        <button type="button" class="profile-toggle-password"
                                            title="Mostrar/ocultar contraseña">
                                            <svg class="icon-password-toggle">
                                                <use href="/images/sprite.svg#icon-eye-alt"></use>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                                <div class="profile-form-actions profile-form-actions--visible">
                                    <button type="submit" class="profile-btn-save">Actualizar contraseña</button>
                                </div>
                            </form>
                        </section>
                        <section class="profile-section" id="avatar">
                            <div class="profile-section-header">
                                <h3 class="profile-section-title">Avatar</h3>
                            </div>
                            <form action="/users/update-avatar/<%= user.id %>" method="POST"
                                enctype="multipart/form-data">
                                <div class="file-input">
                                    <label for="avatar" class="file-label">
                                        <span>Subir imagen de perfil</span>
                                    </label>
                                    <input type="file" name="avatar" id="file-avatar" accept="image/*"
                                        class="file-hidden" required>
                                    <p class="file-name" id="file-name">Ningún archivo seleccionado</p>
                                </div>
                                <div class="profile-form-actions profile-form-actions--visible">
                                    <button type="submit" class="profile-btn-save">
                                        Cambiar foto
                                    </button>
                                </div>
                            </form>
                        </section>
                        <form action="/users/delete/<%= user.id %>" method="POST" class="form-delete">
                            <button type="submit" class="profile-btn-delete"
                                onclick="return confirm('¿Seguro que querés eliminar tu cuenta?')">
                                Eliminar cuenta
                            </button>
                        </form>
                    </div>
                </div>
            </main>
            <%- include("../partials/global/footer") %>
                <%- include("../partials/global/scripts", { js: "user-profile" }) %>
                    </body>

                    </html>