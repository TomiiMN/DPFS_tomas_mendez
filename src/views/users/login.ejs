<%- include("../partials/global/head", { title: "Login" , css: "loginStyle" }) %>
    <%- include("../partials/global/header", { showNav: false }) %>
        <%- include("../partials/global/alerts") %>
            <main>
                <section class="container">
                    <h2 id="tituloForm">Inicio de sesión</h2>
                    <p class="descriptions">Ingresa tus datos para iniciar sesión</p>
                    <form class="login" action="/users/login" method="POST">
                        <input class="login__input" type="email" placeholder="Email*" name="email" id="email"
                            value="<%= oldData?.email || '' %>">
                        <div class="login__password">
                            <div class="input-password-wrapper">
                                <input class="login__input" type="password" name="password" id="password"
                                    placeholder="Contraseña*">
                                <button type="button" class="input-toggle-password" title="Mostrar/ocultar contraseña">
                                    <svg class="icon-password-toggle">
                                        <use href="/images/sprite.svg#icon-eye-alt"></use>
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <div class="login__input-remember">
                            <label class="login__checkbox">
                                <input type="checkbox" id="remember" name="remember">
                                <span class="remember">Recordarme</span>
                            </label>
                            <button type="submit" class="buttonSubmit">Iniciar sesión</button>
                        </div>
                    </form>
                    <p class="descriptions">¿No tienes una cuenta? Registrate <a href="/users/register"
                            class="link-p">aquí</a></p>
                </section>
            </main>


            <%- include("../partials/global/footer") %>
                <%- include("../partials/global/scripts", { js: "login" }) %>
                    </body>

                    </html>