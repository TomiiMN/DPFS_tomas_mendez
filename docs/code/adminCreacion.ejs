<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Producto — Editor</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/adminStyle.css">
    <link rel="stylesheet" href="/css/global/root.css">
</head>

<body>

    <!-- PAGE HEADER -->
    <div class="page-header">
        <div>
            <div class="breadcrumb">
                <a href="#">Admin</a> / <a href="#">Productos</a> / Nuevo producto
            </div>
            <div class="page-title">Editor de producto</div>
        </div>
        <div class="mode-toggle">
            <button class="mode-btn active">✦ Crear</button>
            <button class="mode-btn">Editar</button>
        </div>
    </div>

    <!-- LAYOUT -->
    <div class="layout">

        <!-- LEFT COLUMN -->
        <div style="display:flex;flex-direction:column;gap:14px;">

            <!-- INFORMACIÓN BÁSICA -->
            <div class="card">
                <div class="card-header">
                    <div class="card-icon">◈</div>
                    <div class="card-title">Información básica</div>
                </div>
                <div class="card-body">

                    <div class="field">
                        <label>Nombre del producto <span class="req">*</span></label>
                        <input type="text" placeholder="Ej. Procesador AMD Ryzen 5 5600GT">
                        <div class="field-meta">
                            <span class="field-hint">Sé descriptivo y específico</span>
                            <span class="char-count">0 / 120</span>
                        </div>
                    </div>

                    <div class="field">
                        <label>Descripción <span class="req">*</span></label>
                        <textarea
                            placeholder="Describe las características principales, sus especificaciones, usos y beneficios del producto..."></textarea>
                        <div class="field-meta">
                            <span class="field-hint">Mínimo 60 caracteres recomendado</span>
                            <span class="char-count">0 / 2000</span>
                        </div>
                    </div>

                    <div class="input-row">
                        <div class="field" style="margin:0">
                            <label>Categoría <span class="req">*</span></label>
                            <select id="categorySelect">
                                <option value="" disabled selected>Seleccionar...</option>
                            </select>
                        </div>
                        <div class="field" style="margin:0">
                            <label>Subcategoría</label>
                            <select id="subcategorySelect">
                                <option value="" disabled selected>Seleccionar...</option>
                            </select>
                        </div>
                    </div>

                </div>
            </div>

            <!-- IMÁGENES -->
            <div class="card">
                <div class="card-header">
                    <div class="card-icon">◻</div>
                    <div class="card-title">Imágenes del producto</div>
                </div>
                <div class="card-body">
                    <div class="upload-zone">
                        <span class="upload-icon">⊕</span>
                        <div class="upload-text">
                            <strong>Hacé clic para subir</strong> o arrastrá y soltá acá
                        </div>
                        <div class="upload-meta">PNG, JPG, WEBP · Máx. 5 MB · Mín. 800×800 px</div>
                    </div>
                    <div class="thumb-row">
                        <div class="thumb main-thumb">
                            🖼
                            <span class="thumb-badge">MAIN</span>
                        </div>
                        <div class="thumb">🖼</div>
                        <div class="thumb">🖼</div>
                        <div class="thumb thumb-add">+</div>
                    </div>
                    <div class="field-hint" style="margin-top:8px">La primera imagen es la portada. Podés arrastrar para
                        reordenar.</div>
                </div>
            </div>

            <!-- PRECIO Y STOCK -->
            <div class="card">
                <div class="card-header">
                    <div class="card-icon">◇</div>
                    <div class="card-title">Precio y stock</div>
                </div>
                <div class="card-body">
                    <div class="input-row">
                        <div class="field" style="margin:0">
                            <label>Precio <span class="req">*</span></label>
                            <div class="input-wrap has-prefix">
                                <div class="input-prefix">$</div>
                                <input type="number" placeholder="0.00">
                            </div>
                        </div>
                        <div class="field" style="margin:0">
                            <label>Precio original <span class="hint">— tachado</span></label>
                            <div class="input-wrap has-prefix">
                                <div class="input-prefix">$</div>
                                <input type="number" placeholder="0.00">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ATRIBUTOS -->
            <div class="card">
                <div class="card-header">
                    <div class="card-icon">▽</div>
                    <div class="card-title">Atributos y variantes</div>
                </div>
                <div class="card-body">
                    <div class="input-row">
                        <div class="field" style="margin:0">
                            <label>Socket</label>
                            <div class="tags-wrap">
                                <span class="tag">AM4 Ryzen 5000 <span class="tag-remove">×</span></span>
                                <input class="tag-input" placeholder="Agregar...">
                            </div>
                        </div>
                        <div class="field" style="margin:0">
                            <label>Nucleos</label>
                            <div class="tags-wrap">
                                <span class="tag">6 <span class="tag-remove">×</span></span>
                                <input class="tag-input" placeholder="Agregar...">
                            </div>
                        </div>
                    </div>
                    <div style="height:14px"></div>
                    <div class="input-row">
                        <div class="field" style="margin:0">
                            <label>Marca</label>
                            <input type="text" placeholder="Ej. Nike, Samsung, Sin marca">
                        </div>
                        <div class="field" style="margin:0">
                            <label>Frecuencia Turbo</label>
                            <div class="input-wrap has-suffix">
                                <input type="number" placeholder="0.0">
                                <div class="input-suffix">GHz</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SEO -->
            <div class="card">
                <div class="card-header">
                    <div class="card-icon">△</div>
                    <div class="card-title">SEO y visibilidad</div>
                </div>
                <div class="card-body">

                    <div class="field">
                        <label>Título SEO</label>
                        <input type="text" placeholder="Título para buscadores (Google, Bing...)">
                        <div class="field-meta">
                            <span class="field-hint">Recomendado: 50–60 caracteres</span>
                            <span class="char-count">0 / 60</span>
                        </div>
                    </div>

                    <div class="field">
                        <label>Meta descripción</label>
                        <textarea style="min-height:70px"
                            placeholder="Breve descripción que aparece en los resultados de búsqueda..."></textarea>
                        <div class="field-meta">
                            <span class="field-hint">Recomendado: 150–160 caracteres</span>
                            <span class="char-count">0 / 160</span>
                        </div>
                    </div>

                    <div class="field" style="margin:0">
                        <label>Vista previa en buscadores</label>
                        <div class="seo-preview">
                            <div class="seo-url">techbox.com › productos › amd-ryzen-5-5600gt</div>
                            <div class="seo-title">AMD Ryzen 5 5600GT — TechBox </div>
                            <div class="seo-desc">Encontrá los mejores procesadores AMD. Entrega en todo el país,
                                cuotas sin interés y devolución gratis.</div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- ACTIONS -->
            <div class="card" style="overflow:visible;border:none;background:none;padding:0">
                <div class="actions"
                    style="background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:16px 22px">
                    <button class="btn btn-primary">✦ Publicar producto</button>
                    <button class="btn btn-ghost">Descartar</button>
                </div>
            </div>

        </div>

        <!-- RIGHT COLUMN -->
        <div class="right-col">

            <!-- OPCIONES -->
            <div class="card">
                <div class="card-header">
                    <div class="card-icon">◌</div>
                    <div class="card-title">Opciones</div>
                </div>
                <div class="card-body" style="padding:14px 18px">
                    <div class="toggle-row">
                        <div class="toggle-info">
                            <div class="toggle-label">Destacado</div>
                            <div class="toggle-desc">Aparece en la página de inicio</div>
                        </div>
                        <label class="toggle">
                            <input type="checkbox" checked>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                    <div class="toggle-row">
                        <div class="toggle-info">
                            <div class="toggle-label">En oferta</div>
                            <div class="toggle-desc">Muestra badge de descuento</div>
                        </div>
                        <label class="toggle">
                            <input type="checkbox" checked>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                    <div class="toggle-row">
                        <div class="toggle-info">
                            <div class="toggle-label">Envío gratis</div>
                            <div class="toggle-desc">Icono especial en el listado</div>
                        </div>
                        <label class="toggle">
                            <input type="checkbox">
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                    <div class="toggle-row">
                        <div class="toggle-info">
                            <div class="toggle-label">Permitir reseñas</div>
                            <div class="toggle-desc">Compradores pueden opinar</div>
                        </div>
                        <label class="toggle">
                            <input type="checkbox" checked>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>
            </div>

            <!-- PREVIEW -->
            <div class="preview-card">
                <div class="preview-header">
                    <div class="preview-title">▸ Vista previa en tienda</div>
                </div>
                <div class="preview-body">
                    <div class="preview-img">🖼</div>
                    <div class="preview-category">Procesador · AMD</div>
                    <div class="preview-name">AMD Ryzen 5 5600GT</div>
                    <div class="preview-desc">Procesador de alto rendimiento para gaming y productividad, con tecnología de última generación.</div>
                    <div class="preview-price-row">
                        <div class="preview-price">$230.000</div>
                        <div class="preview-original">$244.000</div>
                        <div class="preview-badge">−6%</div>
                    </div>
                </div>
            </div>

        </div>

    </div>

    <script>
        const categories = <%- JSON.stringify(categories) %>;
        const categorySelect = document.getElementById("categorySelect");
        const subcategorySelect = document.getElementById("subcategorySelect");
        subcategorySelect.disabled = true;
        const mainCategories = categories.filter(cat => cat.parent_id === null);
        mainCategories.forEach(cat => {
            const option = document.createElement("option");
            option.value = cat.id;
            option.textContent = cat.name;
            categorySelect.appendChild(option);
        });
        categorySelect.addEventListener("change", () => {
            const selectedId = categorySelect.value;
            subcategorySelect.disabled = false;
            subcategorySelect.innerHTML = '<option value="" disabled selected>Seleccionar...</option>';
            const subcategories = categories.filter(cat => cat.parent_id == selectedId);
            subcategories.forEach(sub => {
                const option = document.createElement("option");
                option.value = sub.id;
                option.textContent = sub.name;
                subcategorySelect.appendChild(option);
            });
        });
    </script>
</body>

</html>